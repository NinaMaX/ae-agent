# Snowflake connection details (see the case study's shared credentials)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_DATABASE=PERSONIO
SNOWFLAKE_SCHEMA=CRM
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=

# Preferred: a Personal Access Token (connection.py tries this first).
# Password auth alone fails here - this sandbox enforces MFA on password
# logins, which programmatic/API access can't complete. Generate a PAT
# for your user in Snowsight; if you hit "Network policy is required" and
# your role can't create one, self-issue the token with a temporary bypass:
#   ALTER USER "<your_username>" ADD PROGRAMMATIC ACCESS TOKEN <name>
#     DAYS_TO_EXPIRY = 7 MINS_TO_BYPASS_NETWORK_POLICY_REQUIREMENT = 10080;
SNOWFLAKE_PAT=

# Fallback if no PAT is set - will fail on this sandbox until MFA is
# resolved some other way, kept for accounts without an MFA requirement.
SNOWFLAKE_PASSWORD=

# Anthropic API key - console.anthropic.com
ANTHROPIC_API_KEY=

# Google Drive API key (enable the Drive API, create an API key) - works
# without OAuth because the enablement folder is shared as "anyone with the
# link can view"
GOOGLE_DRIVE_API_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Optional - defaults to INFO if unset. DEBUG shows every tool call's full
# arguments and timing (agent.py).
LOG_LEVEL=
